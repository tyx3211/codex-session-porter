{
  "name": "codex-session-porter",
  "version": "0.1.0",
  "description": "Export OpenAI Codex CLI and VS Code chat sessions to Markdown or JSONL, with an Ink TUI picker.",
  "type": "module",
  "bin": {
    "cce": "./dist/cli.js"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyx3211/codex-session-porter.git"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "lint": "eslint src",
    "test": "npm run build && node --test",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm test"
  },
  "dependencies": {
    "ink": "^7.0.1",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
